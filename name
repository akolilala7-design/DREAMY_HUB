--// LOAD YOUR SCRIPT
local success, err = pcall(function()

    loadstring(game:HttpGet("https://raw.githubusercontent.com/akolilala7-design/DREAMY_HUB/997853ff20e4597a05ce2cdd6ff3e4d39a11aac7/name"))()

end)

if success then
    LoadingText.Text = "✅ DREAMYxHUB Loaded"
else
    LoadingText.Text = "❌ Load Failed"
    warn(err)
end

wait(1.5)

--// TWEEN OUT
